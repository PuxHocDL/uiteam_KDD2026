# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv
.python-version

# Local environment files
.env
.env.local
.env.*.local
.codex

# Secrets / credentials — never commit API keys
*.key
*.pem
secrets.*
**/secrets*.json
*.local.yaml
.localcreds
api profile.txt

# Local data and artifacts. NOTE: docs/ and tests/ ARE tracked here — they are
# included in this public submission to support reproducibility.
# `/data/` is anchored to the repo root with a leading slash so it only ignores
# the top-level benchmark dataset — NOT source dirs that share the name, e.g.
# frontend/src/data/ (real modules: agentOptions.js, tools.js, mockData.js).
/data/
evaluation/

# Another copy of the benchmark dataset (~1.8GB) — same reasoning as /data/.
/assets/benchmark data/
artifacts/*
!artifacts/.gitkeep

# Local configs
configs/*
!configs/react_baseline.example.yaml
!configs/dragin_baseline.example.yaml
!configs/hybrid_b_baseline.example.yaml

# Extra data and debug
data_btc/
debug_ui.py

# OS / notebook noise
.DS_Store
.ipynb_checkpoints/

# Docker submission archives — too large for GitHub (>100 MB), regenerated by docker build
image code/team*.tar.gz
*.tar.gz

# Generated submission artifacts (creative_<team_id>_*) — regenerate, don't commit
creative_*_code.zip
creative_*_guide.md
creative_*_report.pdf
creative_*_video.mp4
creative_*_disclosure.pdf

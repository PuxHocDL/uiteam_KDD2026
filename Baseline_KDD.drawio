                <mxCell id="a-subtitle" value="&lt;i&gt;Hệ thống sử dụng ReAct (Reasoning + Acting) pattern: Agent suy nghĩ → chọn tool → nhận observation → lặp lại đến khi có answer&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#666666;" vertex="1" parent="1">

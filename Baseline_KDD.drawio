                </mxCell>
                <mxCell id="t-tool6" value="&lt;b style=&quot;color:#7d6608&quot;&gt;⑥ execute_context_sql&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;Chạy SQL read-only trên&lt;br&gt;SQLite database&lt;hr&gt;&lt;b&gt;Params:&lt;/b&gt;&lt;br&gt;• path: str&lt;br&gt;• sql: str&lt;br&gt;• limit: int (mặc định 200)&lt;hr&gt;&lt;b&gt;Returns:&lt;/b&gt; columns, rows,&lt;br&gt;row_count, truncated&lt;hr&gt;🔒 Chỉ cho: SELECT, WITH, PRAGMA&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" parent="1" vertex="1">

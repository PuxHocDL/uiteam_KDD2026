                </mxCell>
                <mxCell id="a-l1" value="&lt;b&gt;1. Build Messages&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Xây dựng lịch sử&lt;br&gt;hội thoại từ steps&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;shadow=1;" vertex="1" parent="1">

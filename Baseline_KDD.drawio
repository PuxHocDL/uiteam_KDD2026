                <mxCell id="t-fs" value="&lt;b&gt;filesystem.py&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;• resolve_context_path(task, rel_path)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Validate &amp;amp; ngăn directory escape&lt;br&gt;• list_context_tree(task, max_depth)&lt;br&gt;• read_csv_preview(task, path, max_rows)&lt;br&gt;• read_json_preview(task, path, max_chars)&lt;br&gt;• read_doc_preview(task, path, max_chars)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" parent="1" vertex="1">

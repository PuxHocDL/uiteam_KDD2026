                <mxCell id="a-grp-model-title" value="&lt;b style=&quot;font-size:13px;color:#2980b9&quot;&gt;🤖 Model Adapters (agents/model.py)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="40" y="95" width="340" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="a-protocol" value="&lt;b&gt;ModelAdapter&lt;/b&gt; &lt;i&gt;(Protocol)&lt;/i&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;+ complete(messages: list[ModelMessage])&lt;br&gt;&amp;nbsp;&amp;nbsp;→ str (raw LLM response)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="80" y="125" width="280" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="a-openai" value="&lt;b&gt;OpenAIModelAdapter&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;model: str (e.g. &quot;gpt-4o&quot;)&lt;br&gt;api_base: str (OpenAI URL)&lt;br&gt;api_key: str&lt;br&gt;temperature: float (0.0)&lt;hr&gt;Dùng: openai.OpenAI client&lt;br&gt;chat.completions.create()&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="45" y="240" width="195" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="a-azure" value="&lt;b&gt;AzureOpenAIModelAdapter&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;model: str&lt;br&gt;azure_endpoint: str&lt;br&gt;api_key: str&lt;br&gt;api_version: str&lt;br&gt;temperature: float&lt;hr&gt;Dùng: openai.AzureOpenAI&lt;br&gt;Trigger: có api_version&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="250" y="240" width="195" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="a-scripted" value="&lt;b&gt;ScriptedModelAdapter&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;responses: list[str]&lt;br&gt;(hàng đợi responses)&lt;hr&gt;Dùng cho testing/debug&lt;br&gt;Không cần API call&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="130" y="420" width="195" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="a-impl1" value="implements" style="endArrow=block;endFill=0;endSize=12;rounded=1;strokeColor=#82b366;" edge="1" source="a-openai" target="a-protocol" parent="1">

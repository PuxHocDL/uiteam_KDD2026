                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="a-re2" value="tạo từ" style="rounded=1;strokeColor=#82b366;dashed=1;" edge="1" source="a-runresult" target="a-state" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="a-re3" value="chứa" style="rounded=1;strokeColor=#b85450;dashed=1;" edge="1" source="a-runresult" target="a-answer" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="a-parse-note" value="&lt;div style=&quot;text-align:left;padding:5px;font-size:10px&quot;&gt;&lt;b&gt;parse_model_step(raw_response):&lt;/b&gt;&lt;br&gt;1. _strip_json_fence() — Tách JSON từ ```json...```&lt;br&gt;2. _load_single_json_object() — Parse JSON đơn&lt;br&gt;3. Validate thought (str), action (non-empty),&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;action_input (dict)&lt;br&gt;4. Raise ValueError nếu format sai&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=center;fillColor=#ffffcc;strokeColor=#d6b656;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="1250" y="700" width="280" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="a-flow-note" value="&lt;div style=&quot;text-align:left;padding:6px;font-size:10px&quot;&gt;&lt;b&gt;Message History Format:&lt;/b&gt;&lt;br&gt;1️⃣ System: system_prompt + tool descriptions&lt;br&gt;2️⃣ User: task question&lt;br&gt;3️⃣ Mỗi step:&lt;br&gt;&amp;nbsp;&amp;nbsp;• Assistant: raw_response (JSON)&lt;br&gt;&amp;nbsp;&amp;nbsp;• User: observation (kết quả tool)&lt;br&gt;→ Lịch sử dài dần theo mỗi bước&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=center;fillColor=#ffffcc;strokeColor=#d6b656;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="1280" y="150" width="260" height="150" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>

                </mxCell>
                <mxCell id="a-grp-runtime-title" value="&lt;b style=&quot;font-size:13px;color:#e67e22&quot;&gt;📊 Runtime Types (agents/runtime.py) — Lưu trữ trạng thái và kết quả&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="40" y="665" width="600" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="a-steprec" value="&lt;b&gt;StepRecord&lt;/b&gt; &lt;i&gt;(Frozen)&lt;/i&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;step_index: int (1-based)&lt;br&gt;thought: str — suy nghĩ&lt;br&gt;action: str — tên tool&lt;br&gt;action_input: dict — params&lt;br&gt;raw_response: str — LLM raw&lt;br&gt;observation: dict — kết quả tool&lt;br&gt;ok: bool — thành công?&lt;hr&gt;+ to_dict() → dict&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="50" y="700" width="230" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="a-state" value="&lt;b&gt;AgentRuntimeState&lt;/b&gt; &lt;i&gt;(Mutable)&lt;/i&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;steps: list[StepRecord]&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Tất cả steps đã thực thi&lt;br&gt;answer: AnswerTable | None&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Câu trả lời nếu đã submit&lt;br&gt;failure_reason: str | None&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Lý do thất bại&lt;hr&gt;&lt;i&gt;Trạng thái đang chạy&lt;br&gt;của agent trong quá trình&lt;br&gt;thực thi vòng lặp ReAct&lt;/i&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="340" y="700" width="260" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="a-runresult" value="&lt;b&gt;AgentRunResult&lt;/b&gt; &lt;i&gt;(Frozen)&lt;/i&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;task_id: str&lt;br&gt;answer: AnswerTable | None&lt;br&gt;steps: list[StepRecord]&lt;br&gt;failure_reason: str | None&lt;hr&gt;&lt;b&gt;Property:&lt;/b&gt;&lt;br&gt;succeeded → bool&lt;br&gt;&amp;nbsp;&amp;nbsp;(answer != None &amp;amp;&amp;amp; no failure)&lt;hr&gt;+ to_dict() → dict&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="660" y="700" width="260" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="a-answer" value="&lt;b&gt;AnswerTable&lt;/b&gt; &lt;i&gt;(Frozen)&lt;/i&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;columns: list[str]&lt;br&gt;rows: list[list[Any]]&lt;hr&gt;+ to_dict() → {columns, rows}&lt;hr&gt;&lt;i&gt;Kết quả cuối cùng&lt;br&gt;được ghi vào prediction.csv&lt;/i&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="980" y="700" width="220" height="150" as="geometry"/>
                </mxCell>

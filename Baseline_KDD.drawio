                <mxCell id="a-grp-prompt-title" value="&lt;b style=&quot;font-size:13px;color:#8e44ad&quot;&gt;📝 Prompt Module (agents/prompt.py)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="1140" y="95" width="290" height="25" as="geometry"/>

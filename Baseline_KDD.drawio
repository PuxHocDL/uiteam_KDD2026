                <mxCell id="a-sys-prompt" value="&lt;b&gt;REACT_SYSTEM_PROMPT&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;Hướng dẫn agent:&lt;br&gt;• ReAct-style reasoning&lt;br&gt;• Tool-based exploration&lt;br&gt;• JSON response format&lt;br&gt;{thought, action, action_input}&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="1145" y="125" width="280" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="a-builders" value="&lt;b&gt;Prompt Builders&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;• build_system_prompt(tool_descs, sys_prompt)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ System message + tools + ví dụ&lt;br&gt;• build_task_prompt(task)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ User msg với câu hỏi task&lt;br&gt;• build_observation_prompt(obs)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ User msg với kết quả tool&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">

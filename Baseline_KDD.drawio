    <diagram id="agents-react" name="Agents &amp; ReAct Loop">
        <mxGraphModel dx="1822" dy="1062" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1300" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="a-title" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;Agents — Kiến trúc Agent &amp;amp; ReAct Loop&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">

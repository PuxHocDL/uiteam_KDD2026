                <mxCell id="r-cmd1" value="&lt;b style=&quot;color:#1a5276&quot;&gt;📋 status&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;Hiển thị project layout&lt;br&gt;&amp;amp; dataset availability&lt;hr&gt;Output: Bảng paths,&lt;br&gt;task counts by difficulty&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="45" y="130" width="220" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="r-cmd2" value="&lt;b style=&quot;color:#1a5276&quot;&gt;🔍 inspect-task&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;Hiển thị metadata task&lt;br&gt;&amp;amp; context files&lt;hr&gt;Args: TASK_ID --config PATH&lt;br&gt;Output: ID, difficulty,&lt;br&gt;question, file tree&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;" vertex="1" parent="1">
                    <mxGeometry x="290" y="130" width="220" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="r-cmd3" value="&lt;b style=&quot;color:#1e8449&quot;&gt;▶ run-task&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;Chạy ReAct agent trên&lt;br&gt;một task đơn lẻ&lt;hr&gt;Args: TASK_ID --config PATH&lt;br&gt;Gọi: run_single_task()&lt;br&gt;Output: trace.json,&lt;br&gt;prediction.csv&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="45" y="275" width="220" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="r-cmd4" value="&lt;b style=&quot;color:#922b21&quot;&gt;🚀 run-benchmark&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:3px;font-size:10px&quot;&gt;Chạy agent trên toàn bộ&lt;br&gt;hoặc giới hạn N tasks&lt;hr&gt;Args: --config PATH [--limit N]&lt;br&gt;Gọi: run_benchmark()&lt;br&gt;Output: progress bar, summary&lt;br&gt;Rich UI: ok/fail/run/queue&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=center;verticalAlign=top;spacingTop=4;fontSize=11;shadow=1;strokeWidth=2;" vertex="1" parent="1">

                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="a-loop-title" value="&lt;b style=&quot;font-size:15px;color:#c0392b&quot;&gt;🔄 ReAct Loop — Vòng lặp chính (tối đa 16 bước)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">

                    <mxGeometry x="460" y="205" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="a-react" value="&lt;b style=&quot;font-size:14px&quot;&gt;ReActAgent&lt;/b&gt;&lt;br&gt;&lt;i&gt;agents/react.py&lt;/i&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:5px;font-size:11px&quot;&gt;&lt;b&gt;Attributes:&lt;/b&gt;&lt;br&gt;• model: ModelAdapter&lt;br&gt;• tools: ToolRegistry&lt;br&gt;• config: ReActAgentConfig&lt;br&gt;&amp;nbsp;&amp;nbsp;(max_steps = 16 mặc định)&lt;br&gt;• system_prompt: str | None&lt;hr&gt;&lt;b&gt;Methods:&lt;/b&gt;&lt;br&gt;• _build_messages(task, state)&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Xây dựng lịch sử hội thoại&lt;br&gt;• run(task) → AgentRunResult&lt;br&gt;&amp;nbsp;&amp;nbsp;→ Vòng lặp chính ReAct&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2980b9;align=center;verticalAlign=top;spacingTop=5;fontSize=12;shadow=1;strokeWidth=3;" vertex="1" parent="1">
